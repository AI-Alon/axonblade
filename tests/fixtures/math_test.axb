# math_test.axb — tests for arithmetic and numeric operations

test("addition", bladeFN() +/
    assert_eq(1 + 1, 2)
    assert_eq(10 + 32, 42)
    assert_eq(0 + 0, 0)
ECB)

test("subtraction", bladeFN() +/
    assert_eq(10 - 3, 7)
    assert_eq(0 - 5, -5)
ECB)

test("multiplication", bladeFN() +/
    assert_eq(3 * 4, 12)
    assert_eq(0 * 999, 0)
ECB)

test("division", bladeFN() +/
    assert_eq(10 / 2, 5)
    assert_eq(9 / 3, 3)
ECB)

test("modulo", bladeFN() +/
    assert_eq(10 % 3, 1)
    assert_eq(8 % 4, 0)
ECB)

test("power", bladeFN() +/
    assert_eq(2 ** 10, 1024)
    assert_eq(3 ** 3, 27)
ECB)

test("negative numbers", bladeFN() +/
    assert_eq(-5 + 5, 0)
    assert_eq(-3 * -3, 9)
ECB)
